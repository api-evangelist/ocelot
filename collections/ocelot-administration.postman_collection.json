  "info": {
    "_postman_id": "38729765-e051-44b8-9a91-349b4d4bd234",
    "name": "Ocelot Administration API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Ocelot Administration API allows runtime changes to the Ocelot .NET API Gateway configuration via an authenticated HTTP API. It supports retrieving and overwriting the active configuration and clearing output cache regions without restarting the gateway. The API is authenticated via Bearer tokens issued by Ocelot's built-in IdentityServer or an external identity provider.\n\nContact Support:\n Name: Ocelot",
      "type": "text/plain"
    }
  }
